#!/bin/sh
# /etc/init.d/uos-init — UOS TV early boot script
# ================================================
# Alpine Linux OpenRC init script that starts UOS TV system services.
# Placed at /etc/init.d/uos-init on the target rootfs.
#
# This runs after basic system init (networking, filesystems).
# It launches monitord which in turn starts all UOS services.

depend() {
    need net
    need localmount
    after bootmisc
}

start() {
    ebegin "Starting UOS TV services"

    # Create required directories
    mkdir -p /run/uos /var/log/uos /data/apps /data/downloads /tmp/uos
    chmod 1777 /tmp

    # Create /data symlink tree if first boot
    if [ ! -L /etc ] && [ -d /data/etc ]; then
        cp -a /etc/* /data/etc/ 2>/dev/null || true
        rm -rf /etc
        ln -sf /data/etc /etc
    fi

    # Start stardust IPC broker first
    if [ -x /usr/bin/stardustd ]; then
        einfo "Starting stardustd (IPC broker)"
        STARDUST_LOG=info /usr/bin/stardustd \
            --socket /run/uos/bus.sock \
            --ws-addr 127.0.0.1:9090 &
        sleep 1
    fi

    # Start logging daemon
    if [ -x /usr/bin/logd ]; then
        einfo "Starting logd"
        /usr/bin/logd --socket /run/uos/log.sock --log-dir /var/log/uos &
    fi

    # Start all other services via monitord
    if [ -x /usr/bin/monitord ]; then
        einfo "Starting monitord (service supervisor)"
        /usr/bin/monitord --config /usr/share/uos/monitord.yaml &
    else
        # Fallback: manual service start
        einfo "monitord not found, starting services manually"
        for svc in netmd devmand dispald inputd audiod powermand notifd pkgd otad; do
            if [ -x "/usr/bin/$svc" ]; then
                einfo "  Starting $svc"
                "/usr/bin/$svc" &
            fi
        done
    fi

    # Start Luna UI compositor
    if [ -x /usr/bin/cog ]; then
        einfo "Starting Cog (WPE WebKit) with Luna UI"
        cog --config=/usr/share/uos/cog.ini &
    elif [ -x /usr/bin/lumind ]; then
        einfo "Starting lumind compositor"
        /usr/bin/lumind &
    else
        einfo "No compositor available — Luna UI at http://localhost:8080"
    fi

    eend 0
}

stop() {
    ebegin "Stopping UOS TV services"
    killall monitord stardustd logd cog lumind 2>/dev/null || true
    sleep 1
    killall -9 monitord stardustd logd cog lumind 2>/dev/null || true
    eend 0
}

restart() {
    stop
    start
}
